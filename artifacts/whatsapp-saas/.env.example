# Firebase - Variables de entorno del frontend (Vite)
# =====================================================
# Copia este archivo como .env.local y rellena con los valores
# de tu proyecto Firebase (Console → Proyecto → Configuracion → SDK)
#
# Estos valores son publicos (client-side) asi que pueden estar
# en .env.local que SI puedes commitear (pero NO .env con secretos)

VITE_FIREBASE_API_KEY=AIzaSy_TU_API_KEY_AQUI
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
